# Copy to .env and fill in your values (or put one at each subfolder root).
# Grab CHALK_* from your Chalk dashboard → Settings → Tokens.

CHALK_CLIENT_ID=client-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHALK_CLIENT_SECRET=secret-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHALK_ENVIRONMENT_ID=your-env-id
CHALK_API_SERVER=https://api.chalk.ai

# dynamic_queries/
OPENAI_API_KEY=sk-...

# vllm/
HF_TOKEN=hf_...

# opencode/
ANTHROPIC_API_KEY=sk-ant-...
OPENCODE_SERVER_PASSWORD=optional-server-password
